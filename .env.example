# Strong Energy environment example.
# Copy this file to .env.local and fill in the values.
# .env.local is ignored by git.

# Required for server-side contact form delivery. Never prefix with NEXT_PUBLIC_.
ZENDORI_FORM_KEY=YOUR_ZENDORI_FORM_KEY

# Required: Supabase Dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Required: Supabase Dashboard > Project Settings > API > Project API keys
# Use the anon/public/publishable key, never the service_role key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Required for `npm run supabase:setup`.
# Project ref is the id in https://supabase.com/dashboard/project/YOUR_PROJECT_REF
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Required for pushing migrations through the Supabase CLI.
SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD

# Optional: only needed if you are not logged in through `npx supabase login`.
# Create at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Optional: set true if edge functions should be deployed during setup.
DEPLOY_SUPABASE_FUNCTIONS=false

# Optional: only needed when DEPLOY_SUPABASE_FUNCTIONS=true and Resend mail is used.
RESEND_API_KEY=

# Optional: only needed for the admin AI blog generator.
# This key is deployed as a Supabase Edge Function secret and must never use NEXT_PUBLIC_.
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# Optional: used by `npm run supabase:create-admin` to create/update the first admin user.
ADMIN_EMAIL=
ADMIN_PASSWORD=
